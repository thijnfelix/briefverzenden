# Postbode.nu API — haal op via je dashboard op postbode.nu
POSTBODE_API_KEY=jouw_api_key_hier

# Je mailbox customer_code (bijv. "BVNL") — te vinden in Postbode.nu dashboard
POSTBODE_MAILBOX=jouw_customer_code_hier

# UUID van je envelope — maak deze aan via Postbode.nu of de API
POSTBODE_ENVELOPE=jouw_envelope_uuid_hier
